{
  "plansDirectory": ".claude/plans",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(*)"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(rm -rf*)",
      "Bash(del *)",
      "Bash(rmdir *)",
      "Bash(Remove-Item*)",
      "Bash(git commit*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import sys,json; d=json.load(sys.stdin); cmd=d.get('tool_input',{}).get('command',''); exit(0 if any(x in cmd for x in ['dotnet build','dotnet run']) else 1)\" && taskkill //F //IM VBCSCompiler.exe 2>/dev/null; exit 0",
            "statusMessage": "Killing VBCSCompiler..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/build-check.sh",
            "statusMessage": "Formatting & building..."
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/dbcontext-check.sh",
            "statusMessage": "Checking DbContext..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop-notify.sh"
          }
        ]
      }
    ]
  }
}
