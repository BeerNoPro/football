{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(*)"
    ],
    "deny": [
      "Bash(rm *)",
      "Bash(rm -rf*)",
      "Bash(del *)",
      "Bash(rmdir *)",
      "Bash(Remove-Item*)",
      "Bash(git commit*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/build-check.sh",
            "statusMessage": "Formatting & building..."
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/dbcontext-check.sh",
            "statusMessage": "Checking DbContext..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/stop-notify.sh"
          }
        ]
      }
    ]
  }
}
