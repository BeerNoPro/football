# Staging — Fly.io secrets

# PostgreSQL (Neon)
ConnectionStrings__DefaultConnection=

# Redis (Upstash) — chỉ lấy phần redis://... không lấy lệnh redis-cli
ConnectionStrings__Redis=

# JWT — dùng để ký token đăng nhập admin
# Là 1 chuỗi bí mật bất kỳ, càng dài càng tốt (tối thiểu 32 ký tự)
# Chạy lệnh sau để tạo:
#
#   PowerShell:
#   [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Maximum 256 }))
#
# Copy kết quả vào đây:
Jwt__Key=

# URLs (điền sau khi tạo app trên Fly.io)
WebBaseUrl=https://footballblog-web.fly.dev
ApiBaseUrl=https://footballblog-api.fly.dev

ASPNETCORE_ENVIRONMENT=Staging

# API Keys (điền từ dotnet user-secrets)
FootballApi__ApiKey=
AI__Claude__ApiKey=
AI__Gemini__ApiKey=
Telegram__BotToken=
Telegram__ChannelId=
