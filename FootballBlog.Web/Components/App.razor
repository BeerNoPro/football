<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <base href="/" />
    <link rel="stylesheet" href="app.css" />
    <link rel="stylesheet" href="FootballBlog.Web.styles.css" />
    <link rel="stylesheet" href="css/common.css" />
    @* MudBlazor CSS — chỉ load cho admin routes *@
    @if (IsAdminRoute)
    {
        <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet" />
        <link href="_content/MudBlazor/MudBlazor.min.css" rel="stylesheet" />
        <link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet" />
    }
    <HeadOutlet />
</head>

<body>
    <Routes />
    <script src="_framework/blazor.web.js"></script>
    @* MudBlazor JS + Quill — chỉ load cho admin routes *@
    @if (IsAdminRoute)
    {
        <script src="_content/MudBlazor/MudBlazor.min.js"></script>
        <script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
        <script src="js/quill-interop.js"></script>
    }
</body>

</html>

@code {
    [CascadingParameter] private HttpContext? HttpContext { get; set; }

    private bool IsAdminRoute =>
        HttpContext?.Request.Path.StartsWithSegments("/admin") ?? false;
}
