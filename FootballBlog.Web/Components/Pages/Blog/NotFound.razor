@using Microsoft.AspNetCore.Components.Web

<SeoHead Title="404 — Trang không tìm thấy | FootballBlog"
         Description="Trang bạn đang tìm kiếm không tồn tại." />

<div style="display:flex; flex-direction:column; align-items:center; justify-content:center; min-height:60vh; padding:40px; text-align:center;">
    <div style="font-size:64px; margin-bottom:16px;">⚽</div>
    <h1 style="font-size:48px; font-weight:800; color:var(--accent); margin:0 0 8px;">404</h1>
    <div style="font-size:16px; color:var(--text-main); margin-bottom:8px; font-weight:600;">
        Trang không tìm thấy
    </div>
    <div style="font-size:13px; color:var(--muted); margin-bottom:24px;">
        Trang bạn đang tìm kiếm đã bị xóa hoặc không tồn tại.
    </div>
    <div style="display:flex; gap:10px; flex-wrap:wrap; justify-content:center;">
        <a href="/" style="background:var(--accent); color:#000; text-decoration:none; padding:8px 20px; border-radius:6px; font-size:13px; font-weight:600;">
            Trang chủ
        </a>
        <a href="/news" style="background:var(--bg-card); color:var(--text-main); text-decoration:none; padding:8px 20px; border-radius:6px; font-size:13px; border:1px solid var(--border2);">
            Tin tức
        </a>
        <a href="/search" style="background:var(--bg-card); color:var(--text-main); text-decoration:none; padding:8px 20px; border-radius:6px; font-size:13px; border:1px solid var(--border2);">
            Tìm kiếm
        </a>
    </div>
</div>
