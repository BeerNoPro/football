@page "/search"
@layout PublicLayout2Col
@using FootballBlog.Core.DTOs
@inject IPostApiClient PostClient
@inject NavigationManager Nav

<SeoHead Title="@($"Tìm kiếm: {_query} — FootballBlog")"
         Description="@($"Kết quả tìm kiếm cho \"{_query}\" trên FootballBlog")" />

<!-- Search hero -->
<div class="search-hero">
    <div class="search-hero-bar">
        <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"
             style="color:var(--muted); flex-shrink:0;">
            <circle cx="11" cy="11" r="8" /><path d="m21 21-4.35-4.35" />
        </svg>
        <input type="text"
               @bind="_searchInput"
               @bind:event="oninput"
               @onkeydown="OnKeyDown"
               placeholder="Tìm kiếm bài viết, đội bóng, giải đấu..." />
        <button @onclick="DoSearch">Tìm</button>
    </div>
    @if (!string.IsNullOrEmpty(_query))
    {
        <div class="search-meta">
            <span class="search-count">
                @_total kết quả cho "<strong style="color:var(--text);">@_query</strong>"
            </span>
            <div class="search-filters">
                <button class="search-filter-btn active">Tất cả</button>
                <button class="search-filter-btn">Bài viết</button>
                <button class="search-filter-btn">Trận đấu</button>
            </div>
        </div>
    }
</div>

<!-- Results -->
<div class="results-scroll">
    @if (string.IsNullOrEmpty(_query))
    {
        <div style="padding:40px 16px; color:var(--muted); font-size:13px; text-align:center;">
            Nhập từ khóa để tìm kiếm bài viết
        </div>
    }
    else if (_loading)
    {
        <div style="padding:24px 16px; color:var(--muted); font-size:12px;">Đang tìm kiếm...</div>
    }
    else if (_posts.Count == 0)
    {
        <div style="padding:40px 16px; color:var(--muted); text-align:center;">
            <div style="font-size:32px; margin-bottom:8px;">🔍</div>
            <div>Không tìm thấy kết quả cho "@_query"</div>
        </div>
    }
    else
    {
        <div class="result-section-header">Bài viết (@_total)</div>
        <div class="post-results-grid">
            @foreach (var post in _posts)
            {
                <PostCard Post="post" />
            }
        </div>
        <Pagination CurrentPage="_page"
                    TotalPages="_totalPages"
                    OnPageChange="ChangePage" />
    }
</div>

@code {
    [SupplyParameterFromQuery(Name = "q")] public string? Query { get; set; }

    private string _query = "";
    private string _searchInput = "";
    private List<PostSummaryDto> _posts = [];
    private bool _loading = false;
    private int _page = 1;
    private int _totalPages = 1;
    private int _total = 0;
    private const int PageSize = 12;

    protected override async Task OnParametersSetAsync()
    {
        _query = Query?.Trim() ?? "";
        _searchInput = _query;
        if (!string.IsNullOrEmpty(_query))
            await LoadPosts();
    }

    private async Task LoadPosts()
    {
        _loading = true;
        // Phase 4: thay bằng search endpoint thật
        var result = await PostClient.GetPublishedAsync(_page, PageSize);
        if (result != null)
        {
            _posts = result.Items
                .Where(p => p.Title.Contains(_query, StringComparison.OrdinalIgnoreCase)
                         || p.CategoryName.Contains(_query, StringComparison.OrdinalIgnoreCase))
                .ToList();
            _total = _posts.Count;
            _totalPages = result.TotalPages;
        }
        _loading = false;
    }

    private void OnKeyDown(KeyboardEventArgs e) { if (e.Key == "Enter") DoSearch(); }

    private void DoSearch()
    {
        if (!string.IsNullOrWhiteSpace(_searchInput))
            Nav.NavigateTo($"/search?q={Uri.EscapeDataString(_searchInput.Trim())}");
    }

    private async Task ChangePage(int page)
    {
        _page = page;
        await LoadPosts();
    }
}
