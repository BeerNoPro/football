@page "/league/{LeagueId:int}"
@layout PublicLayout3Col
@rendermode InteractiveServer
@using FootballBlog.Core.Models
@inject IFixtureApiClient FixtureClient
@inject NavigationManager Nav

<SeoHead Title="@(_league is not null ? $"{_league.Name} — FootballBlog" : "Giải đấu — FootballBlog")"
         Description="@(_league is not null ? $"Lịch thi đấu, bảng xếp hạng và thống kê {_league.Name} mùa giải hiện tại" : "")" />

@if (_loading)
{
    <div style="padding:48px 16px;text-align:center;color:var(--muted);font-size:12px;">Đang tải...</div>
}
else if (_league is null)
{
    <div style="padding:48px 16px;text-align:center;color:var(--muted);font-size:12px;">Không tìm thấy giải đấu.</div>
}
else
{
    <!-- Breadcrumb -->
    <div class="breadcrumb">
        <a href="/">Trang chủ</a>
        <span>›</span>
        <span>@_league.Name</span>
    </div>

    <!-- League header -->
    <div class="league-header">
        <div class="league-header-top">
            @if (!string.IsNullOrEmpty(_league.LogoUrl))
            {
                <img src="@_league.LogoUrl" alt="@_league.Name" width="40" height="40"
                     style="object-fit:contain;border-radius:4px;flex-shrink:0;" />
            }
            else
            {
                <div class="league-logo-lg">⚽</div>
            }
            <div class="league-info">
                <div class="league-name-lg">@_league.Name</div>
                <div class="league-season">@_league.CountryName · Mùa giải 2024/25</div>
            </div>
        </div>
        <div class="league-stats-row">
            <div class="league-stat-item">
                <div class="league-stat-val">@(_live.Count + _upcoming.Count + _results.Count)</div>
                <div class="league-stat-lbl">Tổng trận</div>
            </div>
            <div class="league-stat-item">
                <div class="league-stat-val">@_upcoming.Count</div>
                <div class="league-stat-lbl">Sắp diễn ra</div>
            </div>
            <div class="league-stat-item">
                <div class="league-stat-val" style="color:var(--accent)">@_standings.Count</div>
                <div class="league-stat-lbl">Đội bóng</div>
            </div>
            <div class="league-stat-item">
                <div class="league-stat-val" style="color:var(--live)">@_live.Count</div>
                <div class="league-stat-lbl">Đang live</div>
            </div>
        </div>
    </div>

    <!-- Tabs: BXH mặc định -->
    <div class="league-tabs tabs">
        <button class="tab-btn @(_tab == "table" ? "active" : "")" @onclick='() => _tab = "table"'>Bảng xếp hạng</button>
        <button class="tab-btn @(_tab == "fixtures" ? "active" : "")" @onclick='() => _tab = "fixtures"'>Lịch đấu</button>
        <button class="tab-btn @(_tab == "results" ? "active" : "")" @onclick='() => _tab = "results"'>Kết quả</button>
    </div>

    <div class="league-scroll">

        @if (_tab == "table")
        {
            <div class="league-panel active">
                @if (_standings.Count == 0)
                {
                    <div style="padding:24px 16px;color:var(--muted);font-size:12px;text-align:center;">
                        Chưa có bảng xếp hạng.
                    </div>
                }
                else
                {
                    <div class="standings-wrap">
                        <table class="standings-table">
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Đội bóng</th>
                                    <th>P</th>
                                    <th>W</th>
                                    <th>D</th>
                                    <th>L</th>
                                    <th>GF</th>
                                    <th>GA</th>
                                    <th>GD</th>
                                    <th>Pts</th>
                                    <th>Form</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var s in _standings)
                                {
                                    <tr>
                                        <td class="rank @ZoneClass(s.Description)">@s.Rank</td>
                                        <td>
                                            <a class="team-cell" href="/team/@s.TeamId">
                                                @if (!string.IsNullOrEmpty(s.TeamLogo))
                                                {
                                                    <img src="@s.TeamLogo" alt="@s.TeamName" width="16" height="16"
                                                         class="team-cell-logo" style="object-fit:contain;" />
                                                }
                                                else
                                                {
                                                    <div class="team-cell-logo">⚽</div>
                                                }
                                                @s.TeamName
                                            </a>
                                        </td>
                                        <td>@s.Played</td>
                                        <td>@s.Won</td>
                                        <td>@s.Drawn</td>
                                        <td>@s.Lost</td>
                                        <td>@s.GoalsFor</td>
                                        <td>@s.GoalsAgainst</td>
                                        <td>@(s.GoalsDiff >= 0 ? $"+{s.GoalsDiff}" : s.GoalsDiff.ToString())</td>
                                        <td class="standings-pts"
                                            style="@(s.Description?.Contains("Champions League") == true ? "color:var(--accent)" : s.Description?.Contains("Relegation") == true ? "color:#f87171" : "")">
                                            @s.Points
                                        </td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(s.Form))
                                            {
                                                <div class="standings-form">
                                                    @foreach (var c in s.Form.TakeLast(5))
                                                    {
                                                        <span class="form-dot @(c == 'W' ? "form-w" : c == 'D' ? "form-d" : "form-l")">
                                                            @(c == 'W' ? "T" : c == 'D' ? "H" : "B")
                                                        </span>
                                                    }
                                                </div>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                        @if (_standings.Any(s => !string.IsNullOrEmpty(s.Description)))
                        {
                            <div style="padding:10px 16px;font-size:10px;color:var(--muted);border-top:1px solid var(--border);display:flex;gap:12px;flex-wrap:wrap;">
                                @if (_standings.Any(s => s.Description?.Contains("Champions League") == true))
                                {
                                    <span><span style="color:var(--accent)">■</span> Champions League</span>
                                }
                                @if (_standings.Any(s => s.Description?.Contains("Europa League") == true && s.Description?.Contains("Conference") != true))
                                {
                                    <span><span style="color:#60a5fa">■</span> Europa League</span>
                                }
                                @if (_standings.Any(s => s.Description?.Contains("Conference") == true))
                                {
                                    <span><span style="color:#34d399">■</span> Conference League</span>
                                }
                                @if (_standings.Any(s => s.Description?.Contains("Relegation") == true))
                                {
                                    <span><span style="color:#f87171">■</span> Xuống hạng</span>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }

        else if (_tab == "fixtures")
        {
            <div class="league-panel active">
                @if (_live.Count == 0 && _upcoming.Count == 0)
                {
                    <div style="padding:24px 16px;color:var(--muted);font-size:12px;text-align:center;">
                        Không có trận đấu sắp diễn ra.
                    </div>
                }
                else
                {
                    var allUpcoming = _live.Concat(_upcoming);
                    @foreach (var grp in allUpcoming
                        .GroupBy(f => DateOnly.FromDateTime(f.KickoffUtc.ToLocalTime()))
                        .OrderBy(g => g.Key))
                    {
                        <div class="date-group-header">@FormatDate(grp.Key)</div>
                        @foreach (var f in grp.OrderBy(f => f.KickoffUtc))
                        {
                            <div class="match-row" style="cursor:pointer;" @onclick='() => Nav.NavigateTo($"/match/{f.Id}")'>
                                <div class="mr-time @(f.Status == MatchStatus.Live ? "is-live" : "")">
                                    @if (f.Status == MatchStatus.Live)
                                    {
                                        <span>LIVE</span>
                                    }
                                    else
                                    {
                                        <span>@f.KickoffUtc.ToLocalTime().ToString("HH:mm")</span>
                                    }
                                </div>
                                <div class="mr-home">
                                    @if (!string.IsNullOrEmpty(f.HomeTeamLogo))
                                    {
                                        <img src="@f.HomeTeamLogo" width="16" height="16" style="object-fit:contain;flex-shrink:0;" />
                                    }
                                    <span class="tn">@f.HomeTeamName</span>
                                </div>
                                <div class="score-c @ScoreClass(f.Status)">
                                    @if (f.Status == MatchStatus.Live)
                                    {
                                        <span>@(f.HomeScore ?? 0) – @(f.AwayScore ?? 0)</span>
                                    }
                                    else
                                    {
                                        <span>–</span>
                                    }
                                </div>
                                <div class="mr-away">
                                    <span class="tn">@f.AwayTeamName</span>
                                    @if (!string.IsNullOrEmpty(f.AwayTeamLogo))
                                    {
                                        <img src="@f.AwayTeamLogo" width="16" height="16" style="object-fit:contain;flex-shrink:0;" />
                                    }
                                </div>
                                <div class="mr-status">
                                    @if (f.Status == MatchStatus.Live)
                                    {
                                        <span class="badge-live"><span class="live-dot"></span> LIVE</span>
                                    }
                                    else if (f.Status == MatchStatus.Postponed)
                                    {
                                        <span class="badge-ft">Hoãn</span>
                                    }
                                    else
                                    {
                                        <span class="badge-sch">@f.KickoffUtc.ToLocalTime().ToString("HH:mm")</span>
                                    }
                                </div>
                            </div>
                        }
                    }
                }
            </div>
        }

        else if (_tab == "results")
        {
            <div class="league-panel active">
                @if (_results.Count == 0)
                {
                    <div style="padding:24px 16px;color:var(--muted);font-size:12px;text-align:center;">
                        Chưa có kết quả.
                    </div>
                }
                else
                {
                    @foreach (var grp in _results
                        .GroupBy(f => DateOnly.FromDateTime(f.KickoffUtc.ToLocalTime()))
                        .OrderByDescending(g => g.Key))
                    {
                        <div class="date-group-header">@FormatDate(grp.Key)</div>
                        @foreach (var f in grp.OrderBy(f => f.KickoffUtc))
                        {
                            <div class="match-row" style="cursor:pointer;" @onclick='() => Nav.NavigateTo($"/match/{f.Id}")'>
                                <div class="mr-time">
                                    <span>@f.KickoffUtc.ToLocalTime().ToString("HH:mm")</span>
                                </div>
                                <div class="mr-home">
                                    @if (!string.IsNullOrEmpty(f.HomeTeamLogo))
                                    {
                                        <img src="@f.HomeTeamLogo" width="16" height="16" style="object-fit:contain;flex-shrink:0;" />
                                    }
                                    <span class="tn">@f.HomeTeamName</span>
                                </div>
                                <div class="score-c has-score">
                                    <span>@(f.HomeScore ?? 0) – @(f.AwayScore ?? 0)</span>
                                </div>
                                <div class="mr-away">
                                    <span class="tn">@f.AwayTeamName</span>
                                    @if (!string.IsNullOrEmpty(f.AwayTeamLogo))
                                    {
                                        <img src="@f.AwayTeamLogo" width="16" height="16" style="object-fit:contain;flex-shrink:0;" />
                                    }
                                </div>
                                <div class="mr-status">
                                    <span class="badge-ft">KT</span>
                                </div>
                            </div>
                        }
                    }
                }
            </div>
        }

    </div>
}

@code {
    [Parameter] public int LeagueId { get; set; }

    private string _tab = "table";
    private bool _loading = true;
    private LeagueDto? _league;
    private List<FixtureDto> _live = [];
    private List<FixtureDto> _upcoming = [];
    private List<FixtureDto> _results = [];
    private List<StandingDto> _standings = [];

    protected override async Task OnParametersSetAsync()
    {
        _loading = true;
        _tab = "table";
        StateHasChanged();

        var leaguesTask = FixtureClient.GetLeaguesAsync();
        var fixturesTask = FixtureClient.GetFixturesAsync(leagueId: LeagueId, pageSize: 500);
        var standingsTask = FixtureClient.GetStandingsAsync(LeagueId);

        await Task.WhenAll(leaguesTask, fixturesTask, standingsTask);

        _league = (leaguesTask.Result ?? []).FirstOrDefault(l => l.Id == LeagueId);

        var all = (fixturesTask.Result?.Items ?? []).ToList();
        _live     = all.Where(f => f.Status == MatchStatus.Live).OrderBy(f => f.KickoffUtc).ToList();
        _upcoming = all.Where(f => f.Status is MatchStatus.Scheduled or MatchStatus.Postponed or MatchStatus.Cancelled).OrderBy(f => f.KickoffUtc).ToList();
        _results  = all.Where(f => f.Status == MatchStatus.Finished).OrderByDescending(f => f.KickoffUtc).ToList();

        _standings = (standingsTask.Result ?? []).ToList();
        _loading = false;
    }

    private static string ZoneClass(string? desc) => desc switch
    {
        { } d when d.Contains("Champions League") => "cl-zone",
        { } d when d.Contains("Conference")       => "conf-zone",
        { } d when d.Contains("Europa League")    => "el-zone",
        { } d when d.Contains("Relegation")       => "rel-zone",
        _                                          => ""
    };

    private static string ScoreClass(MatchStatus status) => status switch
    {
        MatchStatus.Live     => "is-live-score",
        MatchStatus.Finished => "has-score",
        _                    => "no-score"
    };

    private static string FormatDate(DateOnly d)
    {
        var days = new[] { "CN", "T2", "T3", "T4", "T5", "T6", "T7" };
        return $"{d:dd/MM/yyyy} · {days[(int)d.DayOfWeek]}";
    }
}
