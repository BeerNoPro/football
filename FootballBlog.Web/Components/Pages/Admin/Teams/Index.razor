@page "/admin/teams"
@attribute [Authorize]
@rendermode InteractiveServer
@inherits AdminPageBase
@inject NavigationManager Nav

@* Provider phải nằm trong island (cùng circuit) — KHÔNG đặt ở AdminLayout (SSR scope khác) *@
<MudPopoverProvider />

<PageTitle>Đội bóng — Admin | FootballBlog</PageTitle>

<!-- Header -->
<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;flex-wrap:wrap;gap:12px;">
    <div>
        <MudText Typo="Typo.h5" Style="color:#efefef;font-weight:700;margin-bottom:4px;">Đội bóng</MudText>
        <MudText Typo="Typo.body2" Style="color:#666;">156 đội · 12 giải đấu · cập nhật lần cuối 2 giờ trước</MudText>
    </div>
    <MudButton Variant="Variant.Filled" Size="Size.Small"
               StartIcon="@Icons.Material.Filled.Add"
               Style="background:#c8f04d;color:#0d0d0d;font-weight:600;"
               OnClick='() => OpenPanel(null)'>
        Thêm đội
    </MudButton>
</div>

<!-- Stats bar -->
<MudGrid Spacing="3" Style="margin-bottom:24px;">
    <MudItem xs="6" sm="3">
        <MudPaper Style="background:#1c1c1c;border:1px solid #242424;padding:16px 20px;border-radius:10px;">
            <MudText Typo="Typo.caption" Style="color:#666;text-transform:uppercase;letter-spacing:1px;">Tổng đội</MudText>
            <MudText Typo="Typo.h5" Style="color:#efefef;font-weight:700;margin-top:6px;">156</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="6" sm="3">
        <MudPaper Style="background:#1c1c1c;border:1px solid #242424;padding:16px 20px;border-radius:10px;">
            <MudText Typo="Typo.caption" Style="color:#666;text-transform:uppercase;letter-spacing:1px;">Giải đấu</MudText>
            <MudText Typo="Typo.h5" Style="color:#c8f04d;font-weight:700;margin-top:6px;">12</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="6" sm="3">
        <MudPaper Style="background:#1c1c1c;border:1px solid #242424;padding:16px 20px;border-radius:10px;">
            <MudText Typo="Typo.caption" Style="color:#666;text-transform:uppercase;letter-spacing:1px;">Cầu thủ</MudText>
            <MudText Typo="Typo.h5" Style="color:#efefef;font-weight:700;margin-top:6px;">3.247</MudText>
        </MudPaper>
    </MudItem>
    <MudItem xs="6" sm="3">
        <MudPaper Style="background:#1c1c1c;border:1px solid #242424;padding:16px 20px;border-radius:10px;">
            <MudText Typo="Typo.caption" Style="color:#666;text-transform:uppercase;letter-spacing:1px;">Thiếu logo</MudText>
            <MudText Typo="Typo.h5" Style="color:#fbbf24;font-weight:700;margin-top:6px;">8</MudText>
        </MudPaper>
    </MudItem>
</MudGrid>

<!-- Two-panel layout -->
<div style="display:grid;grid-template-columns:@(_panelOpen ? "1fr 380px" : "1fr");gap:16px;height:calc(100vh - 280px);overflow:hidden;">

    <!-- Left: table -->
    <MudPaper Style="background:#1c1c1c;border:1px solid #242424;border-radius:10px;overflow:hidden;display:flex;flex-direction:column;">

        <!-- Filter bar -->
        <div style="padding:14px 20px;border-bottom:1px solid #242424;display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
            <MudSelect @bind-Value="_leagueFilter" Placeholder="Giải đấu" T="string" Clearable="true" Dense="true"
                       Variant="Variant.Outlined" Margin="Margin.Dense"
                       Style="background:#0d0d0d;border-radius:6px;max-width:180px;">
                <MudSelectItem Value="@("premier-league")">🏴󠁧󠁢󠁥󠁮󠁧󠁿 Premier League</MudSelectItem>
                <MudSelectItem Value="@("champions-league")">🏆 Champions League</MudSelectItem>
                <MudSelectItem Value="@("la-liga")">🇪🇸 La Liga</MudSelectItem>
                <MudSelectItem Value="@("bundesliga")">🇩🇪 Bundesliga</MudSelectItem>
                <MudSelectItem Value="@("serie-a")">🇮🇹 Serie A</MudSelectItem>
                <MudSelectItem Value="@("vleague-1")">🇻🇳 V.League 1</MudSelectItem>
            </MudSelect>
            <MudTextField @bind-Value="_search" Placeholder="Tìm tên đội..."
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          Style="background:#0d0d0d;border-radius:6px;max-width:240px;" Variant="Variant.Outlined"
                          Margin="Margin.Dense" />
            <MudText Style="color:#555;font-size:12px;margin-left:auto;">@_teams.Count đội</MudText>
        </div>

        <!-- Table -->
        <div style="overflow-y:auto;flex:1;">
            <MudTable T="TeamRow" Items="_teams" Dense="true" Hover="true"
                      Style="background:transparent;"
                      RowStyle="border-bottom:1px solid #1e1e1e;">
                <HeaderContent>
                    <MudTh Style="color:#555;font-size:11px;text-transform:uppercase;letter-spacing:1px;padding:10px 16px;border-bottom:1px solid #242424;">Đội bóng</MudTh>
                    <MudTh Style="color:#555;font-size:11px;text-transform:uppercase;letter-spacing:1px;padding:10px 16px;border-bottom:1px solid #242424;">Giải đấu</MudTh>
                    <MudTh Style="color:#555;font-size:11px;text-transform:uppercase;letter-spacing:1px;padding:10px 16px;border-bottom:1px solid #242424;">Quốc gia</MudTh>
                    <MudTh Style="color:#555;font-size:11px;text-transform:uppercase;letter-spacing:1px;padding:10px 16px;border-bottom:1px solid #242424;">Cầu thủ</MudTh>
                    <MudTh Style="color:#555;font-size:11px;text-transform:uppercase;letter-spacing:1px;padding:10px 16px;border-bottom:1px solid #242424;">Hành động</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd Style="padding:12px 16px;">
                        <div style="display:flex;align-items:center;gap:10px;">
                            <span style="font-size:20px;">@context.Emoji</span>
                            <div>
                                <div style="color:#efefef;font-size:13px;font-weight:500;">@context.Name</div>
                                <div style="color:#555;font-size:11px;">@context.Slug</div>
                            </div>
                        </div>
                    </MudTd>
                    <MudTd Style="padding:12px 16px;">
                        <MudText Style="color:#999;font-size:12px;">@context.League</MudText>
                    </MudTd>
                    <MudTd Style="padding:12px 16px;">
                        <MudText Style="color:#666;font-size:12px;">@context.Country</MudText>
                    </MudTd>
                    <MudTd Style="padding:12px 16px;">
                        <MudText Style="color:#666;font-size:12px;">@context.PlayerCount</MudText>
                    </MudTd>
                    <MudTd Style="padding:12px 16px;">
                        <div style="display:flex;gap:6px;align-items:center;">
                            <MudButton Size="Size.Small" Variant="Variant.Outlined"
                                       Style="border-color:#333;color:#999;font-size:11px;min-width:0;padding:3px 10px;"
                                       OnClick='() => Nav.NavigateTo($"/admin/players?team={context.Slug}")'>
                                Cầu thủ
                            </MudButton>
                            <MudButton Size="Size.Small" Variant="Variant.Outlined"
                                       Style="border-color:#c8f04d;color:#c8f04d;font-size:11px;min-width:0;padding:3px 10px;"
                                       OnClick="@(() => OpenPanel(context))">
                                Sửa
                            </MudButton>
                            <MudButton Size="Size.Small" Variant="Variant.Outlined"
                                       Style="border-color:#f87171;color:#f87171;font-size:11px;min-width:0;padding:3px 10px;">
                                Xóa
                            </MudButton>
                        </div>
                    </MudTd>
                </RowTemplate>
            </MudTable>
        </div>
    </MudPaper>

    <!-- Right: edit panel -->
    @if (_panelOpen)
    {
        <MudPaper Style="background:#1c1c1c;border:1px solid #242424;border-radius:10px;overflow:hidden;display:flex;flex-direction:column;">
            <div style="padding:16px 20px;border-bottom:1px solid #242424;display:flex;align-items:center;justify-content:space-between;">
                <MudText Typo="Typo.subtitle1" Style="color:#efefef;font-weight:600;">
                    @(_selectedTeam == null ? "Thêm đội bóng" : "Chỉnh sửa đội")
                </MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                               Style="color:#555;" OnClick='() => _panelOpen = false' />
            </div>
            <div style="padding:20px;overflow-y:auto;flex:1;display:flex;flex-direction:column;gap:16px;">
                <MudTextField @bind-Value="_editName" Label="Tên đội" Variant="Variant.Outlined"
                              Margin="Margin.Dense" Style="background:#0d0d0d;border-radius:6px;" />
                <MudTextField @bind-Value="_editSlug" Label="Slug" Variant="Variant.Outlined"
                              Margin="Margin.Dense" Style="background:#0d0d0d;border-radius:6px;"
                              HelperText="lowercase, dấu gạch ngang, ví dụ: manchester-city" />
                <MudTextField @bind-Value="_editCountry" Label="Quốc gia" Variant="Variant.Outlined"
                              Margin="Margin.Dense" Style="background:#0d0d0d;border-radius:6px;" />
                <MudTextField @bind-Value="_editStadium" Label="Sân vận động" Variant="Variant.Outlined"
                              Margin="Margin.Dense" Style="background:#0d0d0d;border-radius:6px;" />
                <MudTextField @bind-Value="_editExternalId" Label="External ID (API-Football)" Variant="Variant.Outlined"
                              Margin="Margin.Dense" Style="background:#0d0d0d;border-radius:6px;" />
            </div>
            <div style="padding:16px 20px;border-top:1px solid #242424;display:flex;gap:8px;">
                <MudButton Variant="Variant.Filled" FullWidth="true"
                           Style="background:#c8f04d;color:#0d0d0d;font-weight:600;">
                    @(_selectedTeam == null ? "Thêm đội" : "Lưu thay đổi")
                </MudButton>
                @if (_selectedTeam != null)
                {
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Variant="Variant.Outlined"
                                   Style="border-color:#f87171;color:#f87171;" Size="Size.Medium" />
                }
            </div>
        </MudPaper>
    }

</div>

@code {
    private bool _panelOpen;
    private TeamRow? _selectedTeam;
    private string? _search;
    private string? _leagueFilter;
    private string _editName = "";
    private string _editSlug = "";
    private string _editCountry = "";
    private string _editStadium = "";
    private string _editExternalId = "";

    private record TeamRow(string Emoji, string Name, string Slug, string League, string Country, int PlayerCount);

    private List<TeamRow> _teams =
    [
        new("🔵", "Manchester City", "manchester-city", "Premier League", "🏴󠁧󠁢󠁥󠁮󠁧󠁿 England", 26),
        new("🔴", "Arsenal", "arsenal", "Premier League", "🏴󠁧󠁢󠁥󠁮󠁧󠁿 England", 25),
        new("🔴", "Liverpool", "liverpool", "Premier League", "🏴󠁧󠁢󠁥󠁮󠁧󠁿 England", 27),
        new("🔵", "Chelsea", "chelsea", "Premier League", "🏴󠁧󠁢󠁥󠁮󠁧󠁿 England", 30),
        new("⚪", "Real Madrid", "real-madrid", "La Liga", "🇪🇸 Spain", 25),
        new("🔵", "Barcelona", "barcelona", "La Liga", "🇪🇸 Spain", 26),
        new("🔴", "Bayern Munich", "bayern-munich", "Bundesliga", "🇩🇪 Germany", 24),
        new("⚫🔴", "AC Milan", "ac-milan", "Serie A", "🇮🇹 Italy", 26),
        new("🏅", "Hà Nội FC", "ha-noi-fc", "V.League 1", "🇻🇳 Vietnam", 25),
        new("🟡", "HAGL", "hagl", "V.League 1", "🇻🇳 Vietnam", 23),
    ];

    private void OpenPanel(TeamRow? team)
    {
        _selectedTeam = team;
        _editName = team?.Name ?? "";
        _editSlug = team?.Slug ?? "";
        _editCountry = team?.Country ?? "";
        _editStadium = "";
        _editExternalId = "";
        _panelOpen = true;
    }
}
