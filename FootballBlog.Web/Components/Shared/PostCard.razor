@using FootballBlog.Core.DTOs

<a href="/posts/@Post.Slug" class="news-card">
    <div class="news-card-thumb" style="background:@PostHelpers.GetThumbBg(Post.Thumbnail);">
        @PostHelpers.GetEmoji(Post.CategoryName)
        <span class="news-card-cat">@Post.CategoryName</span>
    </div>
    <div class="news-card-body">
        <div class="news-card-league">@Post.CategoryName</div>
        <div class="news-card-title">@Post.Title</div>
        <div class="news-card-meta">
            <span class="news-card-time">@PostHelpers.FormatTimeAgo(Post.PublishedAt)</span>
            <span class="news-card-read">Đọc →</span>
        </div>
    </div>
</a>

@code {
    [Parameter, EditorRequired] public PostSummaryDto Post { get; set; } = null!;
}
