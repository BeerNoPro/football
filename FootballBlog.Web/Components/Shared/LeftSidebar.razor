@using System.Security.Claims
@inject NavigationManager Nav
@inject IFixtureApiClient FixtureClient

<aside class="left-sidebar">
    <a href="/" class="logo-wrap" style="display:block; text-decoration:none;">
        <div class="logo">
            <span class="logo-white">FOOTBALL</span><span class="logo-accent">BLOG</span>
        </div>
        <div class="logo-sub">Kết quả &amp; Nhận định AI</div>
    </a>

    <div class="left-search">
        <div class="search-input-wrap">
            <svg class="search-icon" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.2" viewBox="0 0 24 24">
                <circle cx="11" cy="11" r="8" />
                <path d="m21 21-4.35-4.35" />
            </svg>
            <input type="text"
                   placeholder="Tìm giải đấu, đội bóng..."
                   @bind="_searchQuery"
                   @bind:event="oninput"
                   @onkeydown="OnSearchKeyDown" />
        </div>
    </div>

    <div class="league-tree" id="league-tree">
        @if (_loading)
        {
            <div style="padding:12px 14px; color:var(--muted); font-size:11px;">Đang tải...</div>
        }
        else if (_leagueTree.Count == 0)
        {
            <div style="padding:12px 14px; color:var(--muted); font-size:11px;">Không có giải đấu nào.</div>
        }
        else
        {
            @foreach (var group in _filteredTree)
            {
                <div class="country-group">
                    <div class="country-header" @onclick="() => group.IsExpanded = !group.IsExpanded">
                        @if (!string.IsNullOrEmpty(group.FlagUrl))
                        {
                            <img src="@group.FlagUrl" alt="@group.CountryName" class="country-flag-img" width="14" height="10" style="object-fit:cover;border-radius:1px;" />
                        }
                        else
                        {
                            <span class="country-flag">🌐</span>
                        }
                        <span class="country-name">@group.CountryName</span>
                        <svg class="chevron @(group.IsExpanded ? "" : "rotated")" width="10" height="10" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                            <path d="m6 9 6 6 6-6" />
                        </svg>
                    </div>
                    @if (group.IsExpanded)
                    {
                        <div class="sub-leagues">
                            @foreach (var league in group.Leagues)
                            {
                                <a class="league-item @(IsActiveLeague(league.Id) ? "active" : "")"
                                   href="@LeagueHref(league.Id)">
                                    @if (!string.IsNullOrEmpty(league.LogoUrl))
                                    {
                                        <img src="@league.LogoUrl" alt="@league.Name" width="14" height="14" style="object-fit:contain;flex-shrink:0;" />
                                    }
                                    <span>@league.Name</span>
                                </a>
                            }
                        </div>
                    }
                </div>
            }
        }
    </div>

    <div class="left-bottom">
        @if (_isAuthenticated)
        {
            <a href="/admin" class="user-row" style="text-decoration:none;">
                <div class="user-avatar">@_initials</div>
                <div class="user-info">
                    <div class="user-name">@_displayName</div>
                    <div class="user-email">@_email</div>
                </div>
                <a href="/admin/logout" class="logout-btn" title="Đăng xuất"
                   @onclick:stopPropagation="true">
                    <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                        <polyline points="16 17 21 12 16 7" />
                        <line x1="21" y1="12" x2="9" y2="12" />
                    </svg>
                </a>
            </a>
        }
        else
        {
            <a href="/admin/login?returnUrl=/" class="user-row" style="text-decoration:none;">
                <div class="user-avatar" style="font-size:14px;background:rgba(255,255,255,0.05);">⚙</div>
                <div class="user-info">
                    <div class="user-name" style="color:var(--muted);">Admin</div>
                    <div class="user-email" style="color:var(--muted);">Đăng nhập</div>
                </div>
            </a>
        }
    </div>
</aside>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _isAuthenticated;
    private string _displayName = "";
    private string _email = "";
    private string _initials = "A";
    private string _searchQuery = "";
    private bool _loading = true;

    private List<CountryGroup> _leagueTree = [];

    private IEnumerable<CountryGroup> _filteredTree => string.IsNullOrWhiteSpace(_searchQuery)
        ? _leagueTree
        : _leagueTree
            .Select(g => new CountryGroup
            {
                CountryName = g.CountryName,
                FlagUrl = g.FlagUrl,
                IsExpanded = true,
                Leagues = g.Leagues
                    .Where(l => l.Name.Contains(_searchQuery, StringComparison.OrdinalIgnoreCase))
                    .ToList()
            })
            .Where(g => g.Leagues.Count > 0);

    protected override async Task OnInitializedAsync()
    {
        var authTask = AuthState is not null ? AuthState : Task.FromResult<AuthenticationState>(null!);
        var leaguesTask = FixtureClient.GetLeaguesAsync();

        await Task.WhenAll(authTask, leaguesTask);

        // Auth
        var state = authTask.Result;
        if (state?.User.Identity?.IsAuthenticated == true)
        {
            _isAuthenticated = true;
            _displayName = state.User.Identity.Name ?? "Admin";
            _email = state.User.FindFirst(ClaimTypes.Email)?.Value ?? "";
            _initials = _displayName.Length > 0 ? _displayName[0].ToString().ToUpper() : "A";
        }

        // League tree
        var leagues = leaguesTask.Result ?? [];
        _leagueTree = leagues
            .GroupBy(l => l.CountryName)
            .OrderBy(g => g.Key)
            .Select(g => new CountryGroup
            {
                CountryName = g.Key,
                FlagUrl = g.First().CountryFlag,
                IsExpanded = true,
                Leagues = g.Select(l => new LeagueItem
                {
                    Id = l.Id,
                    Name = l.Name,
                    LogoUrl = l.LogoUrl
                }).ToList()
            })
            .ToList();

        _loading = false;
    }

    private string LeagueHref(int leagueId)
    {
        var path = new Uri(Nav.Uri).AbsolutePath.TrimEnd('/');
        return path is "" or "/" ? $"#league-{leagueId}" : $"/league/{leagueId}";
    }

    private bool IsActiveLeague(int leagueId)
    {
        var path = new Uri(Nav.Uri).AbsolutePath.TrimEnd('/');
        return path.EndsWith($"/league/{leagueId}");
    }

    private void OnSearchKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_searchQuery))
            Nav.NavigateTo($"/search?q={Uri.EscapeDataString(_searchQuery.Trim())}");
    }

    private class CountryGroup
    {
        public string CountryName { get; set; } = "";
        public string? FlagUrl { get; set; }
        public bool IsExpanded { get; set; } = true;
        public List<LeagueItem> Leagues { get; set; } = [];
    }

    private class LeagueItem
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string? LogoUrl { get; set; }
    }
}
