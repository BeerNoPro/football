FROM mcr.microsoft.com/dotnet/sdk:8.0 AS build
WORKDIR /src

COPY FootballBlog.Core/FootballBlog.Core.csproj FootballBlog.Core/
COPY FootballBlog.Web/FootballBlog.Web.csproj FootballBlog.Web/
RUN dotnet restore FootballBlog.Web/FootballBlog.Web.csproj

COPY FootballBlog.Core/ FootballBlog.Core/
COPY FootballBlog.Web/ FootballBlog.Web/
RUN dotnet publish FootballBlog.Web/FootballBlog.Web.csproj -c Release -o /app --no-restore

FROM mcr.microsoft.com/dotnet/aspnet:8.0
WORKDIR /app
COPY --from=build /app .
ENV ASPNETCORE_URLS=http://+:8080
EXPOSE 8080
ENTRYPOINT ["dotnet", "FootballBlog.Web.dll"]
